<!-- Queue Health Monitor — runs hourly to detect stuck tasks
     WHY: The orchestrator can't heal itself. A separate monitor detects
     stale claims, dead agents, and queue blockages — then auto-recovers.

     SETUP: Same as orchestrator plist — replace placeholders, copy, load.

     NOTE: StartCalendarInterval uses LOCAL time, NOT UTC.
     WHY (Feb 2026): Plists used UTC hours → agents ran 6h late.
-->
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.[YOUR_COMPANY].queue-health</string>

  <key>ProgramArguments</key>
  <array>
    <string>[YOUR_PROJECT_PATH]/bin/queue-monitor</string>
    <string>--health</string>
  </array>

  <key>WorkingDirectory</key>
  <string>[YOUR_PROJECT_PATH]</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>[YOUR_RUBY_PATH]/bin:/usr/local/bin:/usr/bin:/bin</string>
    <key>LANG</key>
    <string>en_US.UTF-8</string>
  </dict>

  <!-- Run every hour -->
  <key>StartInterval</key>
  <integer>3600</integer>

  <key>StandardOutPath</key>
  <string>[YOUR_PROJECT_PATH]/log/queue-health.log</string>
  <key>StandardErrorPath</key>
  <string>[YOUR_PROJECT_PATH]/log/queue-health-error.log</string>
</dict>
</plist>
