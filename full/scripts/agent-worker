#!/usr/bin/env ruby
# frozen_string_literal: true
# encoding: UTF-8

# Agent Worker - Entry point for spawned Claude Code agents
#
# WHY THIS EXISTS: The orchestrator spawns workers for each task. The worker
# handles context injection, heartbeat monitoring, output parsing, and
# completion reporting. Without it, spawned agents have no way to report
# back to the orchestrator.
#
# Environment variables (set by orchestrator):
#   AGENT_TASK_ID        - Task ID (e.g., WQ-029)
#   AGENT_ROLE           - Agent role (coder, product, marketing, etc.)
#   AGENT_LOG_FILE       - Path to log file
#   AGENT_STATE_FILE     - Path to .running state file
#   AGENT_COMPLETION_FILE - Path to write completion status
#   AGENT_BRIEF          - Path to task brief (optional)
#   ORCHESTRATOR_API_URL - API base URL
#   ORCHESTRATOR_API_TOKEN - API token for auth

# WHY: Early crash capture — write marker before any requires.
# If this line never appears in logs, the crash is in Ruby startup itself.
$stdout.sync = true
$stderr.sync = true
puts "[#{Time.now.strftime("%Y-%m-%d %H:%M:%S")}] [Worker #{ENV["AGENT_TASK_ID"]}] BOOT: ruby=#{RUBY_VERSION} pid=#{Process.pid} role=#{ENV["AGENT_ROLE"]}"

Encoding.default_external = Encoding::UTF_8
Encoding.default_internal = Encoding::UTF_8

require "yaml"
require "time"
require "open3"
require "net/http"
require "json"

PROJECT_DIR = File.expand_path("..", __dir__)

CLAUDE_TIMEOUT_SECONDS = 3600  # 1 hour max

HEARTBEAT_INTERVAL = 30
# WHY: Git-pushing roles (coder, marketing) must be serialized to prevent
# overlapping deploys. Feb 2026: 4 pushes in 18min caused 2 concurrent CI runs.
GIT_PUSHING_ROLES = %w[coder marketing].freeze

class AgentWorker
  def initialize
    @task_id = ENV["AGENT_TASK_ID"]
    @role = ENV["AGENT_ROLE"] || "coder"
    @log_file = ENV["AGENT_LOG_FILE"]
    @state_file = ENV["AGENT_STATE_FILE"]
    @completion_file = ENV["AGENT_COMPLETION_FILE"]
    @brief_path = ENV["AGENT_BRIEF"]
    @api_url = ENV["ORCHESTRATOR_API_URL"] || "https://[YOUR_DOMAIN]"
    @heartbeat_thread = nil
    @stop_heartbeat = false

    validate_environment
  end

  def run
    log "Agent worker starting for task #{@task_id} (#{@role})"

    task = load_task_from_api
    unless task
      report_failure("Task #{@task_id} not found")
      return 1
    end

    # Update task status to in_progress
    update_task_status("in_progress")

    # Build the system prompt context
    context = build_context(task)

    # Start heartbeat thread
    # WHY: Heartbeat lets the orchestrator know the agent is still alive.
    # Without it, stale tasks can't be detected and reset.
    start_heartbeat

    # Run Claude Code
    output = run_claude(context)

    # Stop heartbeat
    stop_heartbeat

    # Parse output for completion signals
    result = parse_output(output)

    # Report completion
    report_completion(result)

    0
  rescue StandardError => e
    log "FATAL: #{e.message}\n#{e.backtrace&.first(5)&.join("\n")}"
    report_failure(e.message)
    1
  end

  private

  def validate_environment
    %w[AGENT_TASK_ID AGENT_ROLE].each do |var|
      raise "Missing #{var}" unless ENV[var]
    end
  end

  def load_task_from_api
    # WHY: Load task details from API, not local file. This ensures
    # the worker always has the latest task state.
    token = load_token
    uri = URI.parse("#{@api_url}/[YOUR_API_PREFIX]/orchestrator/api/tasks/#{@task_id}")
    http = Net::HTTP.new(uri.host, uri.port)
    http.use_ssl = uri.scheme == "https"
    request = Net::HTTP::Get.new(uri.request_uri)
    request["X-Orchestrator-Token"] = token
    response = http.request(request)
    JSON.parse(response.body)["task"]
  rescue StandardError => e
    log "Failed to load task: #{e.message}"
    nil
  end

  def build_context(task)
    # WHY: Context injection is how the agent knows what to work on.
    # The system prompt includes task details, brief content, and
    # the autonomous task instructions.
    lines = []
    lines << "# AUTONOMOUS TASK CONTEXT"
    lines << ""
    lines << "## Task Details"
    lines << "- ID: #{task["task_id"]}"
    lines << "- Subject: #{task["subject"]}"
    lines << "- Type: #{task["task_type"]}"
    lines << "- Priority: #{task["priority"]}"
    lines << ""

    # Load brief if specified
    if @brief_path && File.exist?(@brief_path)
      lines << "## Brief"
      lines << File.read(@brief_path)
      lines << ""
    end

    # Add task notes
    if task["notes"]
      lines << "## Notes"
      lines << task["notes"]
      lines << ""
    end

    lines << "## Instructions"
    lines << "1. Read and understand the task requirements"
    lines << "2. Complete the work autonomously"
    lines << "3. Output TASK_COMPLETE, NEEDS_REVIEW, or BLOCKED"

    lines.join("\n")
  end

  def run_claude(context)
    # WHY: Use --agent + --append-system-prompt, not --system-prompt with
    # raw content. --agent respects frontmatter (model, tools). --system-prompt
    # ignores frontmatter entirely.
    cmd = [
      "claude",
      "--print",
      "--agent", @role,
      "--append-system-prompt", context,
      "--dangerously-skip-permissions",
      "--verbose"
    ]

    log "Running: #{cmd.first(4).join(" ")} ..."

    output = ""
    # WHY: Use Process.spawn + deadline thread instead of Timeout.timeout.
    # Ruby Timeout cannot reliably kill blocking I/O (Feb 2026 zombie incident).
    pid = nil
    reader, writer = IO.pipe

    pid = Process.spawn(
      # WHY: CLAUDECODE must be unset or child agents crash with "nested session"
      { "CLAUDECODE" => nil },
      *cmd,
      out: writer,
      err: writer,
      chdir: PROJECT_DIR
    )
    writer.close

    # Deadline thread
    deadline_thread = Thread.new do
      sleep CLAUDE_TIMEOUT_SECONDS
      if pid
        log "TIMEOUT: Killing agent after #{CLAUDE_TIMEOUT_SECONDS}s"
        Process.kill("TERM", pid) rescue nil
        sleep 5
        Process.kill("KILL", pid) rescue nil
      end
    end

    # Read output
    output = reader.read
    reader.close

    # Wait for process
    _, status = Process.wait2(pid)
    deadline_thread.kill

    # Write to log file
    File.write(@log_file, output) if @log_file

    log "Claude exited with status #{status.exitstatus}"
    output
  end

  def parse_output(output)
    # WHY: Structured completion signals let the orchestrator distinguish
    # between success, review-needed, and failure without parsing free text.
    if output.include?("TASK_COMPLETE")
      { result: "completed", notes: extract_summary(output) }
    elsif output.include?("NEEDS_REVIEW")
      { result: "needs_review", notes: extract_summary(output) }
    elsif output.include?("BLOCKED")
      { result: "blocked", notes: extract_summary(output) }
    else
      # WHY: Check for rate limit messages. If the agent hit a limit but
      # also produced TASK_COMPLETE, treat as success (work was done).
      if output.match?(/hit your limit|out of extra usage/i)
        { result: "failed", notes: "Rate limit hit" }
      else
        { result: "needs_review", notes: "No completion signal found" }
      end
    end
  end

  def extract_summary(output)
    # Extract text after the completion signal
    match = output.match(/(?:TASK_COMPLETE|NEEDS_REVIEW|BLOCKED):\s*(.+?)(?:\n|$)/)
    match ? match[1].strip : "See log for details"
  end

  def start_heartbeat
    @heartbeat_thread = Thread.new do
      until @stop_heartbeat
        write_heartbeat
        sleep HEARTBEAT_INTERVAL
      end
    end
  end

  def stop_heartbeat
    @stop_heartbeat = true
    @heartbeat_thread&.join(5)
  end

  def write_heartbeat
    # Write to local state file
    if @state_file
      File.write(@state_file, {
        "task_id" => @task_id,
        "role" => @role,
        "pid" => Process.pid,
        "last_heartbeat" => Time.now.iso8601
      }.to_yaml)
    end

    # Also send to remote API
    update_task_heartbeat
  rescue StandardError => e
    log "Heartbeat error: #{e.message}"
  end

  def report_completion(result)
    # Write local completion file
    if @completion_file
      File.write(@completion_file, result.to_yaml)
    end

    # Update via API
    case result[:result]
    when "completed"
      update_task_status("complete")
    when "needs_review"
      update_task_status("needs_review")
    when "failed"
      fail_task(result[:notes])
    when "blocked"
      update_task_status("needs_review")
    end

    log "Task #{@task_id} → #{result[:result]}: #{result[:notes]}"
  end

  def report_failure(reason)
    fail_task(reason)
  end

  # API helpers (implement these for your API)
  def update_task_status(status)
    api_post("/[YOUR_API_PREFIX]/orchestrator/api/tasks/#{@task_id}/#{status}")
  end

  def update_task_heartbeat
    api_post("/[YOUR_API_PREFIX]/orchestrator/api/tasks/#{@task_id}/heartbeat")
  end

  def fail_task(reason)
    api_post("/[YOUR_API_PREFIX]/orchestrator/api/tasks/#{@task_id}/fail",
             { last_failure: reason })
  end

  def api_post(path, body = nil)
    token = load_token
    uri = URI.parse("#{@api_url}#{path}")
    http = Net::HTTP.new(uri.host, uri.port)
    http.use_ssl = uri.scheme == "https"
    request = Net::HTTP::Post.new(uri.request_uri)
    request["X-Orchestrator-Token"] = token
    request["Content-Type"] = "application/json"
    request.body = body.to_json if body
    http.request(request)
  rescue StandardError => e
    log "API error: #{e.message}"
  end

  def load_token
    ENV["ORCHESTRATOR_API_TOKEN"] ||
      (File.exist?(File.expand_path("~/.orchestrator-token")) &&
       File.read(File.expand_path("~/.orchestrator-token")).strip)
  end

  def log(msg)
    puts "[#{Time.now.strftime("%Y-%m-%d %H:%M:%S")}] [Worker #{@task_id}] #{msg}"
  end
end

# Run
exit AgentWorker.new.run
